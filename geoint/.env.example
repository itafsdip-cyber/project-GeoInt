# Frontend (Vite) live data base URL
# Used by src/services/data/adapters/liveProviders.js
VITE_GEOINT_LIVE_API_BASE=http://localhost:3001

# Backend live ingestion provider toggles
# Recommended local baseline: enable GDELT + RSS, keep Reddit/X disabled until credentials are set.
GEOINT_ENABLE_GDELT=true
GEOINT_ENABLE_REDDIT=false
GEOINT_ENABLE_X=false
GEOINT_ENABLE_RSS=true

# GDELT provider
GEOINT_GDELT_QUERY=conflict OR military OR ceasefire OR sanctions
GEOINT_GDELT_LIMIT=50
GEOINT_GDELT_REFRESH_MS=120000

# RSS provider
# Comma-separated feed URLs
GEOINT_RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml
GEOINT_RSS_REFRESH_MS=300000

# Reddit provider (server-side only; placeholders)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=geoint-live-monitor/1.0
GEOINT_REDDIT_SUBREDDITS=worldnews,geopolitics,news
GEOINT_REDDIT_KEYWORDS=geopolitics,conflict,diplomacy
GEOINT_REDDIT_REFRESH_MS=180000

# X provider (server-side only; placeholders)
X_BEARER_TOKEN=your_x_bearer_token
GEOINT_X_QUERY=(geopolitics OR conflict OR diplomacy) -is:retweet lang:en
GEOINT_X_MAX_RESULTS=25
GEOINT_X_REFRESH_MS=180000

# Optional Anthropic proxy key (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key
